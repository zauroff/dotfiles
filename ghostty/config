# Tab bar — blocky and minimal
window-theme = ghostty
macos-option-as-alt = true

# True-black background so the amber CRT shader doesn't tint the empty screen
background = f9f9f9
foreground = 000000

# Retro pixel font (chunky by design); light thicken for a touch more weight
font-family = DepartureMono Nerd Font
font-thicken = true
font-thicken-strength = 40
font-size = 16
# macos-titlebar-style = hidden

# Amber CRT look (custom GLSL shader, symlinked next to this config)
custom-shader = crt-light.glsl
custom-shader-animation = false

# Split keybindings (ctrl+opt)
keybind = ctrl+opt+s=new_split:right
keybind = ctrl+opt+v=new_split:down
keybind = ctrl+opt+w=close_surface

# Pane navigation (ctrl+opt+arrows)
keybind = ctrl+opt+left=goto_split:left
keybind = ctrl+opt+right=goto_split:right
keybind = ctrl+opt+up=goto_split:top
keybind = ctrl+opt+down=goto_split:bottom

# Tab navigation (cmd+opt+arrows, matches Chrome/Arc)
keybind = cmd+opt+left=previous_tab
keybind = cmd+opt+right=next_tab

# New tab
keybind = cmd+t=new_tab
