" =============================================================================
" .ideavimrc — LazyVim-compatible keybindings for JetBrains IDEs
" =============================================================================

" ---------------------------------------------------------------------------
" General settings
" ---------------------------------------------------------------------------
let mapleader = " "
set scrolloff=8
set incsearch
set ignorecase
set smartcase
set number
set relativenumber
set clipboard+=unnamed
set ideajoin
set idearefactormode=keep

" ---------------------------------------------------------------------------
" IdeaVim built-in plugins
" ---------------------------------------------------------------------------
set surround
set commentary
set argtextobj
set highlightedyank
set NERDTree
set which-key
set notimeout

source ~/.lazy-idea/lazy-idea.vim
